    "@types/styled-components": "5.1.35",
    "@vitejs/plugin-react-swc": "4.2.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxlint": "1.25.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "unplugin-auto-import": "20.2.0",
    "vite": "7.2.0",
