{
  "name": "employer-react-boilerplate",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Minimal Vite + React + TypeScript starter aligned with employer-frontend conventions",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint --fix ./src/**/*.{ts,tsx}",
    "tsc": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react-swc": "4.2.1",
    "oxlint": "1.25.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "vite": "7.2.0",
    "vite-tsconfig-paths": "5.1.4"
  }
}
